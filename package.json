{
  "name": "tippani",
  "version": "1.2.0",
  "description": "Offline-capable CLI that renders Azure DevOps PR markdown files as a clean review portal",
  "type": "module",
  "bin": {
    "tippani": "./src/index.js"
  },
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/index.js",
    "build:client": "node scripts/build-client.js",
    "build": "node scripts/build.js"
  },
  "keywords": [
    "azure-devops",
    "ado",
    "pull-request",
    "review",
    "markdown",
    "cli",
    "offline",
    "spec"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mavaali/tippani.git"
  },
  "homepage": "https://github.com/mavaali/tippani",
  "author": "Mihir Wagle",
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/markdown": "^1.6.4",
    "azure-devops-node-api": "15.1.2",
    "express": "5.2.1",
    "open": "^11.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-sanitize": "6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "postject": "^1.0.0-alpha.6"
  },
  "license": "MIT"
}
